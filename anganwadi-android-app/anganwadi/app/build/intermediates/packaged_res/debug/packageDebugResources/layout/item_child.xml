<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="12dp"
    android:gravity="center_vertical">

    <!-- Avatar circle -->
    <TextView android:id="@+id/tvInitial"
        android:layout_width="44dp" android:layout_height="44dp"
        android:gravity="center" android:textSize="18sp" android:textStyle="bold"
        android:textColor="@color/white" android:background="@drawable/circle_green"/>

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical"
        android:layout_marginStart="12dp">
        <TextView android:id="@+id/tvChildName"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="15sp" android:textStyle="bold" android:textColor="@color/text"/>
        <TextView android:id="@+id/tvChildAge"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="12sp" android:textColor="@color/muted"/>
    </LinearLayout>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="›" android:textSize="20sp" android:textColor="@color/muted"/>
</LinearLayout>
