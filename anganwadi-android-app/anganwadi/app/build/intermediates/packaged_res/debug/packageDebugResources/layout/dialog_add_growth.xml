<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="vertical" android:padding="20dp">
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="WEIGHT (kg)" style="@style/LabelText" android:layout_marginBottom="4dp"/>
    <EditText android:id="@+id/etWeight" android:layout_width="match_parent" android:layout_height="48dp"
        android:hint="e.g. 10.5" android:inputType="numberDecimal" android:padding="10dp"
        android:background="@drawable/input_bg" android:layout_marginBottom="12dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="HEIGHT (cm)" style="@style/LabelText" android:layout_marginBottom="4dp"/>
    <EditText android:id="@+id/etHeight" android:layout_width="match_parent" android:layout_height="48dp"
        android:hint="e.g. 84.0" android:inputType="numberDecimal" android:padding="10dp"
        android:background="@drawable/input_bg" android:layout_marginBottom="12dp"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="NUTRITION STATUS" style="@style/LabelText" android:layout_marginBottom="4dp"/>
    <Spinner android:id="@+id/spStatus" android:layout_width="match_parent" android:layout_height="48dp"
        android:background="@drawable/input_bg" android:layout_marginBottom="12dp"
        android:entries="@array/nutrition_options"/>
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="REMARKS" style="@style/LabelText" android:layout_marginBottom="4dp"/>
    <EditText android:id="@+id/etRemarks" android:layout_width="match_parent" android:layout_height="60dp"
        android:hint="Optional notes..." android:inputType="textMultiLine" android:gravity="top"
        android:padding="10dp" android:background="@drawable/input_bg"/>
</LinearLayout>
