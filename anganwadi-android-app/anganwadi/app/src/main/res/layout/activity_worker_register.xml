<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="24dp" android:layout_marginTop="8dp">
            <ImageButton android:id="@+id/btnBack"
                android:layout_width="40dp" android:layout_height="40dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="@null"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Worker Registration" android:textSize="20sp"
                    android:textStyle="bold" android:textColor="@color/text"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Create your Anganwadi worker account"
                    android:textSize="12sp" android:textColor="@color/muted"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Form Card -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" app:cardCornerRadius="16dp"
            app:cardElevation="4dp" android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="FULL NAME" android:textSize="11sp" android:textColor="@color/muted"
                    android:textAllCaps="true" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/etName"
                    android:layout_width="match_parent" android:layout_height="50dp"
                    android:hint="Enter your full name" android:padding="12dp"
                    android:background="@drawable/input_bg" android:inputType="textPersonName"
                    android:layout_marginBottom="14dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="PHONE NUMBER" android:textSize="11sp" android:textColor="@color/muted"
                    android:textAllCaps="true" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/etPhone"
                    android:layout_width="match_parent" android:layout_height="50dp"
                    android:hint="10-digit mobile number" android:padding="12dp"
                    android:background="@drawable/input_bg" android:inputType="phone"
                    android:maxLength="10" android:layout_marginBottom="14dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="DESIGNATION (Optional)" android:textSize="11sp" android:textColor="@color/muted"
                    android:textAllCaps="true" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/etDesignation"
                    android:layout_width="match_parent" android:layout_height="50dp"
                    android:hint="e.g. Anganwadi Worker" android:padding="12dp"
                    android:background="@drawable/input_bg" android:inputType="textCapWords"
                    android:layout_marginBottom="14dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="ANGANWADI CENTER ID" android:textSize="11sp" android:textColor="@color/muted"
                    android:textAllCaps="true" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/etCenterId"
                    android:layout_width="match_parent" android:layout_height="50dp"
                    android:hint="e.g. AWC_001" android:padding="12dp"
                    android:background="@drawable/input_bg" android:inputType="textCapCharacters"
                    android:layout_marginBottom="6dp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Get this from your supervisor or district office"
                    android:textSize="11sp" android:textColor="@color/muted"
                    android:layout_marginBottom="14dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="PASSWORD" android:textSize="11sp" android:textColor="@color/muted"
                    android:textAllCaps="true" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/etPassword"
                    android:layout_width="match_parent" android:layout_height="50dp"
                    android:hint="Minimum 6 characters" android:padding="12dp"
                    android:background="@drawable/input_bg" android:inputType="textPassword"
                    android:layout_marginBottom="14dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="CONFIRM PASSWORD" android:textSize="11sp" android:textColor="@color/muted"
                    android:textAllCaps="true" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/etConfirmPassword"
                    android:layout_width="match_parent" android:layout_height="50dp"
                    android:hint="Re-enter password" android:padding="12dp"
                    android:background="@drawable/input_bg" android:inputType="textPassword"
                    android:layout_marginBottom="20dp"/>

                <ProgressBar android:id="@+id/progressBar"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center" android:visibility="gone"
                    android:indeterminateTint="@color/green_dark"
                    android:layout_marginBottom="8dp"/>

                <Button android:id="@+id/btnRegister"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:text="CREATE WORKER ACCOUNT" android:textSize="15sp"
                    android:textStyle="bold" android:backgroundTint="@color/green_dark"
                    android:textColor="@color/white"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <View android:layout_width="match_parent" android:layout_height="30dp"/>
    </LinearLayout>
</ScrollView>
