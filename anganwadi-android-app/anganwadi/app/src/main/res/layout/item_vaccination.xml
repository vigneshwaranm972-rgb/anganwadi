<?xml version="1.0" encoding="utf-8"?>
<!-- item_vaccination.xml — REPLACE existing file -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:orientation="horizontal" android:padding="12dp" android:gravity="center_vertical">

    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
        android:layout_weight="1" android:orientation="vertical">
        <TextView android:id="@+id/tvVaccineName"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="14sp" android:textStyle="bold" android:textColor="@color/text"/>
        <TextView android:id="@+id/tvDueDate"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="12sp" android:textColor="@color/muted"/>
    </LinearLayout>

    <!-- Status badge -->
    <TextView android:id="@+id/tvStatus"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:textSize="11sp" android:textStyle="bold"
        android:padding="6dp" android:minWidth="70dp" android:gravity="center"
        android:layout_marginEnd="8dp"/>

    <!-- ✅ FEATURE 2: Mark Given button — hidden when status=given -->
    <Button android:id="@+id/btnMarkGiven"
        android:layout_width="wrap_content" android:layout_height="36dp"
        android:text="Mark\nGiven" android:textSize="10sp"
        android:backgroundTint="@color/green_dark" android:textColor="@color/white"
        android:visibility="gone" android:paddingStart="10dp" android:paddingEnd="10dp"/>
</LinearLayout>
