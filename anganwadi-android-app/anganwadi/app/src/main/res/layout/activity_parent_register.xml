<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="24dp" android:layout_marginTop="8dp">
            <ImageButton android:id="@+id/btnBack"
                android:layout_width="40dp" android:layout_height="40dp"
                android:src="@android:drawable/ic_media_previous"
                android:background="@null"/>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical" android:layout_marginStart="8dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Parent Registration" android:textSize="20sp"
                    android:textStyle="bold" android:textColor="@color/text"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Create your account to track your child"
                    android:textSize="12sp" android:textColor="@color/muted"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Form Card -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" app:cardCornerRadius="16dp"
            app:cardElevation="4dp" android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="20dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="YOUR FULL NAME" android:textSize="11sp" android:textColor="@color/muted"
                    android:textAllCaps="true" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/etName"
                    android:layout_width="match_parent" android:layout_height="50dp"
                    android:hint="Mother / Guardian name" android:padding="12dp"
                    android:background="@drawable/input_bg" android:inputType="textPersonName"
                    android:layout_marginBottom="14dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="PHONE NUMBER" android:textSize="11sp" android:textColor="@color/muted"
                    android:textAllCaps="true" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/etPhone"
                    android:layout_width="match_parent" android:layout_height="50dp"
                    android:hint="10-digit mobile number" android:padding="12dp"
                    android:background="@drawable/input_bg" android:inputType="phone"
                    android:maxLength="10" android:layout_marginBottom="14dp"/>

                <!-- Step 2 — Find child -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="@drawable/card_blue"
                    android:padding="14dp" android:layout_marginBottom="14dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ANGANWADI CENTER ID" android:textSize="11sp" android:textColor="@color/blue"
                        android:textAllCaps="true" android:layout_marginBottom="6dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical">
                        <EditText android:id="@+id/etCenterId"
                            android:layout_width="0dp" android:layout_height="50dp"
                            android:layout_weight="1" android:hint="e.g. AWC_001" android:padding="12dp"
                            android:background="@drawable/input_bg" android:inputType="textCapCharacters"
                            android:layout_marginEnd="8dp"/>
                        <Button android:id="@+id/btnLoadChildren"
                            android:layout_width="wrap_content" android:layout_height="50dp"
                            android:text="Find" android:textSize="13sp"
                            android:backgroundTint="@color/blue" android:textColor="@color/white"
                            android:paddingStart="16dp" android:paddingEnd="16dp"/>
                    </LinearLayout>

                    <TextView android:id="@+id/tvChildNote"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Enter your Anganwadi center ID and tap Find to see your child"
                        android:textSize="12sp" android:textColor="@color/blue"
                        android:layout_marginTop="8dp" android:visibility="gone"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="SELECT YOUR CHILD" android:textSize="11sp" android:textColor="@color/blue"
                        android:textAllCaps="true" android:layout_marginTop="12dp"
                        android:layout_marginBottom="6dp"/>

                    <Spinner android:id="@+id/spChild"
                        android:layout_width="match_parent" android:layout_height="50dp"
                        android:background="@drawable/input_bg" android:enabled="false"
                        android:padding="8dp"/>
                </LinearLayout>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="PASSWORD" android:textSize="11sp" android:textColor="@color/muted"
                    android:textAllCaps="true" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/etPassword"
                    android:layout_width="match_parent" android:layout_height="50dp"
                    android:hint="Minimum 6 characters" android:padding="12dp"
                    android:background="@drawable/input_bg" android:inputType="textPassword"
                    android:layout_marginBottom="14dp"/>

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="CONFIRM PASSWORD" android:textSize="11sp" android:textColor="@color/muted"
                    android:textAllCaps="true" android:layout_marginBottom="6dp"/>
                <EditText android:id="@+id/etConfirmPassword"
                    android:layout_width="match_parent" android:layout_height="50dp"
                    android:hint="Re-enter password" android:padding="12dp"
                    android:background="@drawable/input_bg" android:inputType="textPassword"
                    android:layout_marginBottom="20dp"/>

                <ProgressBar android:id="@+id/progressBar"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center" android:visibility="gone"
                    android:indeterminateTint="@color/blue"
                    android:layout_marginBottom="8dp"/>

                <Button android:id="@+id/btnRegister"
                    android:layout_width="match_parent" android:layout_height="52dp"
                    android:text="CREATE PARENT ACCOUNT" android:textSize="15sp"
                    android:textStyle="bold" android:backgroundTint="@color/blue"
                    android:textColor="@color/white"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <View android:layout_width="match_parent" android:layout_height="30dp"/>
    </LinearLayout>
</ScrollView>
